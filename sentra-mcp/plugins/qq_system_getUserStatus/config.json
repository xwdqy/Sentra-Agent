{
  "name": "qq_system_getUserStatus",
  "description": "查询一个或多个 QQ 号的在线状态。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "integer"
      },
      "user_ids": {
        "type": "array",
        "items": {
          "type": "integer"
        },
        "minItems": 1
      },
      "requestId": {
        "type": "string"
      }
    },
    "anyOf": [
      {
        "required": [
          "user_id"
        ]
      },
      {
        "required": [
          "user_ids"
        ]
      }
    ],
    "additionalProperties": true
  },
  "timeoutMs": 20000,
  "trigger_keywords": [
    "查在线状态",
    "用户状态",
    "user status",
    "online status"
  ],
  "trigger_patterns": [
    "(查在线状态|用户状态).{0,12}(user status|online status)",
    "(user status|online status).{0,12}(查在线状态|用户状态)",
    "(查在线状态|用户状态|user status|online status)"
  ],
  "keyword_boost": 60,
  "regex_boost": 86
}
