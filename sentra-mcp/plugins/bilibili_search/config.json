{
  "name": "bilibili_search",
  "description": "搜索 B 站视频并下载到本地，或以自定义音乐卡片形式发送到QQ群聊/私聊",
  "inputSchema": {
    "type": "object",
    "properties": {
      "keyword": {
        "type": "string",
        "description": "单个搜索关键词（视频标题/关键字），例如：\"鬼灭之刃 MAD\"。若需要一次搜索多个关键词，请使用 keywords[]。"
      },
      "keywords": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1,
        "description": "搜索关键词数组（视频标题/关键字），例如：[\"鬼灭之刃 MAD\", \"进击的巨人 AMV\"]"
      },
      "pick": {
        "type": "string",
        "enum": [
          "first",
          "random"
        ],
        "description": "选择第一条或随机一条，默认 first"
      },
      "user_id": {
        "type": "string",
        "description": "私聊对象的 user_id（可选，发送音乐卡片时需提供至少一个ID，同时提供时优先使用 group_id）"
      },
      "group_id": {
        "type": "string",
        "description": "群聊对象的 group_id（可选，发送音乐卡片时需提供至少一个ID，同时提供时优先使用此参数）"
      },
      "send_as_music_card": {
        "type": "boolean",
        "description": "是否以自定义音乐卡片形式发送（覆盖env配置）"
      }
    },
    "anyOf": [
      {
        "required": [
          "keyword"
        ]
      },
      {
        "required": [
          "keywords"
        ]
      }
    ],
    "additionalProperties": true
  },
  "timeoutMs": 180000,
  "trigger_keywords": [
    "B站",
    "bilibili",
    "视频搜索",
    "up主",
    "番剧",
    "BV",
    "av号"
  ],
  "trigger_patterns": [
    "(B站|bilibili).{0,12}(视频搜索|up主|番剧|BV|av号)",
    "(视频搜索|up主|番剧|BV|av号).{0,12}(B站|bilibili)",
    "(B站|bilibili|视频搜索|up主|番剧|BV|av号)"
  ],
  "keyword_boost": 64,
  "regex_boost": 88
}
