# 是否启用插件
# 启用插件
# type: boolean
# options: true | false
PLUGIN_ENABLED=true

# 插件超时时间（毫秒）
# 插件超时（毫秒）
# type: number
# range: 60000-300000
PLUGIN_TIMEOUT_MS=150000

# 搜索顺序模式（auto | gemini | tavily | serper | model）
# auto: Gemini官方搜索 -> Tavily -> Serper -> 纯模型
# type: enum
# options: auto | gemini | tavily | serper | model
REALTIME_SEARCH_PROVIDER=auto

# 兜底总结/纯模型回答使用的 OpenAI 兼容接口
# type: string
REALTIME_SEARCH_BASE_URL=https://yuanplus.chat/v1

# 兜底总结/纯模型回答使用的 OpenAI 兼容密钥
# type: string
REALTIME_SEARCH_API_KEY=sk-

# 兜底总结/纯模型回答使用的模型
# type: string
REALTIME_SEARCH_MODEL=gemini-2.5-flash

# 上游搜索接口超时（毫秒）
# type: number
# range: 5000-120000
REALTIME_SEARCH_UPSTREAM_TIMEOUT_MS=30000

# Gemini 官方联网搜索
# Google AI Studio 的官方 Key
# type: string
GEMINI_NATIVE_API_KEY=AIzaSy-REPLACE_ME

# 官方模型名（未来改模型无需改代码）
# type: string
GEMINI_NATIVE_MODEL=gemini-2.5-flash

# 官方 Gemini API 根地址
# type: string
GEMINI_NATIVE_BASE_URL=https://generativelanguage.googleapis.com

# Tavily联网搜索
#Tavily的key
# type: string
TAVILY_API_KEY=tvly-REPLACE_ME

# Tavily 地址
# type: string
TAVILY_BASE_URL=https://api.tavily.com/search

# Serper联网搜索
# Serper的key
# type: string
SERPER_API_KEY=REPLACE_ME

#Serper的地址
# type: string
SERPER_BASE_URL=https://google.serper.dev/search

# 查询缓存 TTL（毫秒），默认 24h
# type: number
REALTIME_SEARCH_CACHE_TTL_MS=86400000

# 查询缓存最大条目数（内存）
# type: number
REALTIME_SEARCH_CACHE_MAX_SIZE=500

# 批量查询项之间间隔（毫秒）
# type: number
REALTIME_SEARCH_BATCH_DELAY_MS=250

# 插件内部请求超时时间（毫秒）
# type: number
# range: 10000-300000
timeoutMs=90000
