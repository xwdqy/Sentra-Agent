# 是否启用插件
# 启用插件
# type: boolean
# options: true | false
PLUGIN_ENABLED=true

# 插件超时时间（毫秒）
# 插件超时（毫秒）
# type: number
# range: 60000-300000
PLUGIN_TIMEOUT_MS=150000

# 搜索提供方：openai_compatible | gemini | tavily
# type: string
REALTIME_SEARCH_PROVIDER=openai_compatible

# OpenAI 兼容搜索：API 基础地址（适用于 newapi 等中转）
# type: string
REALTIME_SEARCH_BASE_URL=https://yuanplus.chat/v1

# OpenAI 兼容搜索：API Key
# type: string
REALTIME_SEARCH_API_KEY=sk-

# 搜索模型（按提供方选择对应模型名）
# openai_compatible 示例：gpt-4o-search / gemini-2.5-flash-search
# gemini 示例：gemini-2.5-flash
# tavily 可随意填写（仅用于返回字段展示）
# type: string
REALTIME_SEARCH_MODEL=gpt-4o-search

# Gemini 原生接口配置（provider=gemini 时生效）
# type: string
REALTIME_SEARCH_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# type: string
REALTIME_SEARCH_GEMINI_API_KEY=

# Tavily 接口配置（provider=tavily 时生效）
# type: string
REALTIME_SEARCH_TAVILY_BASE_URL=https://api.tavily.com
# type: string
REALTIME_SEARCH_TAVILY_API_KEY=

# 实时搜索工具的内部请求超时时间（毫秒）
# 内部请求超时（毫秒）
# type: number
# range: 10000-300000
timeoutMs=90000