{
  "name": "qq_group_info",
  "description": "QQ平台：查询群信息",
  "inputSchema": {
    "type": "object",
    "properties": {
      "group_id": {
        "type": "integer"
      },
      "group_ids": {
        "type": "array",
        "items": {
          "type": "integer"
        },
        "minItems": 1
      },
      "refresh": {
        "type": "boolean",
        "default": false
      },
      "requestId": {
        "type": "string"
      }
    },
    "anyOf": [
      {
        "required": [
          "group_id"
        ]
      },
      {
        "required": [
          "group_ids"
        ]
      }
    ],
    "additionalProperties": true
  },
  "timeoutMs": 20000,
  "trigger_keywords": [
    "群信息",
    "群资料",
    "group info",
    "group profile"
  ],
  "trigger_patterns": [
    "(群信息|群资料).{0,12}(group info|group profile)",
    "(group info|group profile).{0,12}(群信息|群资料)",
    "(群信息|群资料|group info|group profile)"
  ],
  "keyword_boost": 62,
  "regex_boost": 87
}
