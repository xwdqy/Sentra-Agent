{
  "name": "qq_avatar_get",
  "description": "下载一个或多个 QQ 号的头像，并返回本地图片路径。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "单个 QQ 号码（字符串或可转字符串）。若需要一次获取多个 QQ 号头像，请使用 user_ids[]。"
      },
      "user_ids": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1,
        "description": "QQ 号码数组（批量模式，必填其一：user_id/user_ids）。"
      },
      "useCache": {
        "type": "boolean",
        "description": "是否使用缓存，默认 true"
      }
    },
    "anyOf": [
      {
        "required": [
          "user_id"
        ]
      },
      {
        "required": [
          "user_ids"
        ]
      }
    ],
    "additionalProperties": true
  },
  "timeoutMs": 60000,
  "trigger_keywords": [
    "查头像",
    "获取头像",
    "avatar",
    "qq avatar"
  ],
  "trigger_patterns": [
    "(查头像|获取头像).{0,12}(avatar|qq avatar)",
    "(avatar|qq avatar).{0,12}(查头像|获取头像)",
    "(查头像|获取头像|avatar|qq avatar)"
  ],
  "keyword_boost": 62,
  "regex_boost": 87
}
