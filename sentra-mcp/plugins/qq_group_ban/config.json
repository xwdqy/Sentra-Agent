{
  "name": "qq_group_ban",
  "description": "QQ平台：对群成员禁言",
  "inputSchema": {
    "type": "object",
    "properties": {
      "group_id": {
        "type": "integer"
      },
      "user_id": {
        "type": "integer"
      },
      "duration": {
        "type": "integer",
        "default": 600
      },
      "requestId": {
        "type": "string"
      }
    },
    "required": [
      "group_id",
      "user_id"
    ],
    "additionalProperties": true
  },
  "timeoutMs": 20000,
  "trigger_keywords": [
    "禁言",
    "群禁言",
    "mute member",
    "group ban"
  ],
  "trigger_patterns": [
    "(禁言|群禁言).{0,12}(mute member|group ban)",
    "(mute member|group ban).{0,12}(禁言|群禁言)",
    "(禁言|群禁言|mute member|group ban)"
  ],
  "keyword_boost": 72,
  "regex_boost": 95
}
