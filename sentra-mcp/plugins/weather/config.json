{
  "name": "weather",
  "description": "全面的天气查询服务，支持使用城市名称查询天气，智能缓存城市ID和天气数据。Comprehensive weather service using city names with smart caching for city IDs and weather data.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "city": {
        "type": "string",
        "description": "单个城市名称（字符串），如：\"北京\"。若需一次查询多个城市，请使用 cities[]。"
      },
      "cities": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1,
        "description": "城市名称数组，如：[\"北京\", \"上海\"]。支持中文和拼音。Array of city names in Chinese or Pinyin, e.g., [Beijing, Shanghai]."
      },
      "queryType": {
        "type": "string",
        "enum": [
          "current",
          "hourly",
          "forecast",
          "warning",
          "all"
        ],
        "default": "all",
        "description": "查询类型：current(当前天气)、hourly(24小时预报)、forecast(7天预报)、warning(预警)、all(全部信息)"
      },
      "lang": {
        "type": "string",
        "default": "zh",
        "description": "语言，默认 zh（中文）"
      },
      "unit": {
        "type": "string",
        "enum": [
          "m",
          "i"
        ],
        "default": "m",
        "description": "单位制：m(公制)、i(英制)"
      }
    },
    "anyOf": [
      {
        "required": [
          "city"
        ]
      },
      {
        "required": [
          "cities"
        ]
      }
    ],
    "additionalProperties": true
  },
  "timeoutMs": 12000,
  "trigger_keywords": [
    "天气",
    "气温",
    "降雨",
    "weather",
    "forecast"
  ],
  "trigger_patterns": [
    "(天气|气温).{0,12}(降雨|weather|forecast)",
    "(降雨|weather|forecast).{0,12}(天气|气温)",
    "(天气|气温|降雨|weather|forecast)"
  ],
  "keyword_boost": 62,
  "regex_boost": 86
}
