{
  "name": "qq_system_setModelShow",
  "description": "设置当前 QQ 账号的设备展示信息。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "model": {
        "type": "string"
      },
      "model_show": {
        "type": "string"
      },
      "requestId": {
        "type": "string"
      }
    },
    "required": [
      "model",
      "model_show"
    ],
    "additionalProperties": true
  },
  "timeoutMs": 20000,
  "trigger_keywords": [
    "设置机型展示",
    "改机型",
    "set model show"
  ],
  "trigger_patterns": [
    "(设置机型展示|改机型).{0,12}(set model show)",
    "(set model show).{0,12}(设置机型展示|改机型)",
    "(设置机型展示|改机型|set model show)"
  ],
  "keyword_boost": 64,
  "regex_boost": 89
}
