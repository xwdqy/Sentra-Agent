{
  "name": "qq_account_setQQProfile",
  "description": "修改当前 QQ 账号的个人资料，比如昵称、签名或性别。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "nickname": {
        "type": "string",
        "description": "昵称"
      },
      "personal_note": {
        "type": "string",
        "description": "个性签名"
      },
      "sex": {
        "type": "string",
        "enum": [
          "0",
          "1",
          "2"
        ],
        "description": "性别：0未知 1男 2女"
      }
    },
    "anyOf": [
      {
        "required": [
          "nickname"
        ]
      },
      {
        "required": [
          "personal_note"
        ]
      },
      {
        "required": [
          "sex"
        ]
      }
    ],
    "required": [],
    "additionalProperties": true
  },
  "timeoutMs": 20000,
  "trigger_keywords": [
    "改资料",
    "设置资料",
    "qq profile",
    "set profile"
  ],
  "trigger_patterns": [
    "(改资料|设置资料).{0,12}(qq profile|set profile)",
    "(qq profile|set profile).{0,12}(改资料|设置资料)",
    "(改资料|设置资料|qq profile|set profile)"
  ],
  "keyword_boost": 65,
  "regex_boost": 90
}
