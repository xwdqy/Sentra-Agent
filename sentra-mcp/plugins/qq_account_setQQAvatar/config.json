{
  "name": "qq_account_setQQAvatar",
  "description": "把当前 QQ 账号的头像换成你提供的图片。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "file": {
        "type": "string",
        "description": "头像图片文件路径。**必须使用绝对路径**（包含完整盘符或根目录），不能使用相对路径。支持格式：jpg/png/gif/webp 等。",
        "examples": [
          "E:/images/avatar.jpg",
          "C:/Users/Admin/Pictures/profile.png",
          "/home/user/images/avatar.jpg",
          "/tmp/uploaded_avatar.png"
        ]
      }
    },
    "required": [
      "file"
    ],
    "additionalProperties": true
  },
  "timeoutMs": 20000,
  "trigger_keywords": [
    "改头像",
    "设置头像",
    "qq avatar",
    "set avatar"
  ],
  "trigger_patterns": [
    "(改头像|设置头像).{0,12}(qq avatar|set avatar)",
    "(qq avatar|set avatar).{0,12}(改头像|设置头像)",
    "(改头像|设置头像|qq avatar|set avatar)"
  ],
  "keyword_boost": 68,
  "regex_boost": 93
}
