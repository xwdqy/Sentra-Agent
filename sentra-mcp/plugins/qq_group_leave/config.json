{
  "name": "qq_group_leave",
  "description": "QQ平台：退出群聊",
  "inputSchema": {
    "type": "object",
    "properties": {
      "group_id": {
        "type": "integer"
      },
      "dismiss": {
        "type": "boolean",
        "default": false
      },
      "requestId": {
        "type": "string"
      }
    },
    "required": [
      "group_id"
    ],
    "additionalProperties": true
  },
  "timeoutMs": 20000,
  "trigger_keywords": [
    "退群",
    "离开群",
    "leave group",
    "quit group"
  ],
  "trigger_patterns": [
    "(退群|离开群).{0,12}(leave group|quit group)",
    "(leave group|quit group).{0,12}(退群|离开群)",
    "(退群|离开群|leave group|quit group)"
  ],
  "keyword_boost": 70,
  "regex_boost": 93
}
