{
  "name": "system_info",
  "description": "Get comprehensive system information: OS, CPU, GPU, memory, disk, network, process, battery, USB, audio, display, BIOS, environment, users, services, software, temperature, Bluetooth, printers. Supports querying single or multiple categories simultaneously. Cross-platform (Windows/Linux/macOS).",
  "inputSchema": {
    "type": "object",
    "properties": {
      "category": {
        "type": "string",
        "enum": [
          "all",
          "os",
          "cpu",
          "memory",
          "gpu",
          "disk",
          "network",
          "process",
          "battery",
          "usb",
          "audio",
          "display",
          "bios",
          "environment",
          "users",
          "services",
          "software",
          "temperature",
          "bluetooth",
          "printers"
        ],
        "description": "Single category to retrieve (deprecated, use 'categories' for multiple). Use 'all' for complete system overview."
      },
      "categories": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "all",
            "os",
            "cpu",
            "memory",
            "gpu",
            "disk",
            "network",
            "process",
            "battery",
            "usb",
            "audio",
            "display",
            "bios",
            "environment",
            "users",
            "services",
            "software",
            "temperature",
            "bluetooth",
            "printers"
          ]
        },
        "minItems": 1,
        "description": "Multiple categories to retrieve simultaneously (e.g., ['cpu', 'gpu', 'memory']). Overrides 'category' if provided."
      },
      "detailed": {
        "type": "boolean",
        "default": true,
        "description": "Include detailed technical specifications and metrics."
      },
      "useCache": {
        "type": "boolean",
        "default": true,
        "description": "Enable smart caching for system information (default: 7 days TTL)"
      },
      "cacheScope": {
        "type": "string",
        "enum": [
          "memory",
          "file",
          "both"
        ],
        "default": "both",
        "description": "Cache storage scope: memory-only, file-only, or both"
      },
      "cacheTTL": {
        "type": "integer",
        "minimum": 60,
        "maximum": 2592000,
        "default": 604800,
        "description": "Cache time-to-live in seconds (default: 604800 = 7 days)"
      }
    },
    "additionalProperties": true
  },
  "cooldownMs": 0,
  "timeoutMs": 30000,
  "trigger_keywords": [
    "系统信息",
    "machine info",
    "cpu",
    "memory",
    "disk",
    "runtime"
  ],
  "trigger_patterns": [
    "(系统信息|machine info).{0,12}(cpu|memory|disk|runtime)",
    "(cpu|memory|disk|runtime).{0,12}(系统信息|machine info)",
    "(系统信息|machine info|cpu|memory|disk|runtime)"
  ],
  "keyword_boost": 61,
  "regex_boost": 87
}
