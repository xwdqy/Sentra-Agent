{
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Whether executed steps are successful."
    },
    "incomplete": {
      "type": "boolean",
      "description": "Whether the user objective is still incomplete."
    },
    "nextAction": {
      "type": "string",
      "enum": ["perfect", "supplement", "replan"],
      "description": "Decision for next orchestration action."
    },
    "completionLevel": {
      "type": "string",
      "enum": ["perfect", "partial", "poor"],
      "description": "Overall completion quality."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for this evaluation."
    },
    "failedSteps": {
      "type": "array",
      "description": "Failed steps list. If success=false, this should usually be non-empty.",
      "items": {
        "type": "object",
        "properties": {
          "displayIndex": {
            "type": "integer",
            "description": "Human-readable step index starting from 1."
          },
          "stepId": {
            "type": "string",
            "description": "Stable step ID in the plan."
          },
          "aiName": {
            "type": "string",
            "description": "Tool name that failed."
          },
          "reason": {
            "type": "string",
            "description": "Concrete reason for failure."
          }
        },
        "required": ["stepId", "reason"]
      }
    },
    "missingGoals": {
      "type": "array",
      "description": "Missing deliverables from user perspective.",
      "items": {
        "type": "string"
      }
    },
    "feedbackUsedCount": {
      "type": "integer",
      "minimum": 0,
      "description": "How many assistant feedback messages are used as evidence."
    },
    "feedbackEvidence": {
      "type": "array",
      "description": "Evidence list from assistant feedback, each item must include phase and excerpt.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "phase": { "type": "string" },
          "excerpt": { "type": "string", "minLength": 1 },
          "ts": { "type": "number" }
        },
        "required": ["phase", "excerpt"],
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Concise summary of what is done, missing, and why."
    }
  },
  "required": ["success", "incomplete", "feedbackUsedCount", "feedbackEvidence", "summary"],
  "allOf": [
    {
      "if": {
        "properties": {
          "success": { "const": false }
        },
        "required": ["success"]
      },
      "then": {
        "required": ["failedSteps"],
        "properties": {
          "failedSteps": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
