{
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Whether the overall task is successful."
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable final summary."
    },
    "failedSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stepId": { "type": "string" },
          "displayIndex": { "type": "integer" },
          "aiName": { "type": "string" },
          "reason": { "type": "string" }
        },
        "required": ["stepId", "reason"],
        "additionalProperties": true
      }
    },
    "highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "eventTimeline": {
      "type": "array",
      "description": "Key execution events in chronological order.",
      "items": {
        "type": "object",
        "properties": {
          "index": { "type": "integer" },
          "stepId": { "type": "string" },
          "aiName": { "type": "string" },
          "status": { "type": "string" },
          "event": { "type": "string" }
        },
        "required": ["event"],
        "additionalProperties": true
      }
    },
    "issues": {
      "type": "array",
      "description": "Execution issues, root causes, and impact.",
      "items": {
        "type": "object",
        "properties": {
          "stepId": { "type": "string" },
          "aiName": { "type": "string" },
          "severity": { "type": "string" },
          "reason": { "type": "string" },
          "impact": { "type": "string" }
        },
        "required": ["reason"],
        "additionalProperties": true
      }
    },
    "completion": {
      "type": "object",
      "description": "Overall completion verdict.",
      "properties": {
        "status": { "type": "string" },
        "goalMet": { "type": "boolean" },
        "completionLevel": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": true
    },
    "unresolvedItems": {
      "type": "array",
      "description": "Unresolved items or missing goals.",
      "items": { "type": "string" }
    },
    "nextActions": {
      "type": "array",
      "description": "Concrete suggested next actions.",
      "items": { "type": "string" }
    },
    "toolEvidence": {
      "type": "array",
      "description": "Tool evidence lines used in summary.",
      "items": { "type": "string" }
    },
    "feedbackEvidence": {
      "type": "array",
      "description": "Bot feedback evidence lines used in summary.",
      "items": { "type": "string" }
    }
  },
  "required": ["success", "summary", "toolEvidence", "feedbackEvidence"],
  "additionalProperties": false
}
