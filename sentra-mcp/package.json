{
  "name": "sentra-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Plan-and-Execute MCP framework with Redis metrics, MCP Server/Client adapters, OpenAI tools+tool_choice integration.",
  "main": "src/mcp/server/index.js",
  "exports": {
    ".": {
      "import": "./src/sdk/index.js"
    },
    "./sdk": {
      "import": "./src/sdk/index.js"
    },
    "./server": {
      "import": "./src/mcp/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "sideEffects": false,
  "scripts": {
    "start": "node src/mcp/server/index.js",
    "dev": "node --watch src/mcp/server/index.js",
    "check:encoding": "node scripts/check_text_integrity.js",
    "postinstall": "puppeteer browsers install chrome",
    "gen:skills": "node scripts/generate_skill_docs.js",
    "gen:skills:overwrite": "node scripts/generate_skill_docs.js --overwrite",
    "skills:normalize-usage": "node scripts/normalize_skill_usage_sections.js",
    "export:tools": "node scripts/export_tools.js --format both",
    "export:tools:md": "node scripts/export_tools.js --format md",
    "export:tools:xml": "node scripts/export_tools.js --format xml"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@xterm/headless": "^5.5.0",
    "@microsoft/recognizers-text-date-time": "^1.0.2",
    "@microsoft/recognizers-text-suite": "^1.0.2",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@mozilla/readability": "^0.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "archiver": "^7.0.1",
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "chrono-node": "^2.6.4",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "docx": "^9.5.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.3.2",
    "form-data": "^4.0.1",
    "html-entities": "^2.6.0",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.3.2",
    "jsdom": "^24.1.0",
    "luxon": "^3.4.4",
    "mammoth": "^1.6.0",
    "markdown-it": "^13.0.2",
    "mime-types": "^3.0.2",
    "node-html-parser": "^6.1.10",
    "openai": "^4.59.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "pptxgenjs": "^3.12.0",
    "puppeteer": "^24.23.0",
    "qs": "^6.13.0",
    "tiktoken": "^1.0.10",
    "ulid": "^2.4.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "ws": "^8.17.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  }
}
